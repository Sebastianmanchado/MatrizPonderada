# =====================================================================
# Variables de entorno locales.
# Copiar a .env (mismo directorio que este archivo) y completar.
# El .env está gitignoreado: NUNCA commitear credenciales reales.
# =====================================================================

# --------------------------------------------------------------------
# Conexión al SQL Server (somee.com en este caso).
# Connection string original (.NET):
#   workstation id=GIA_DB_PoC.mssql.somee.com;packet size=4096;
#   user id=jppirra_SQLLogin_1;data source=GIA_DB_PoC.mssql.somee.com;
#   persist security info=False;initial catalog=GIA_DB_PoC;
#   TrustServerCertificate=True
#
# Equivalente JDBC (lo que entiende Spring):
# --------------------------------------------------------------------
DATABASE_URL=jdbc:sqlserver://GIA_DB_PoC.mssql.somee.com:1433;databaseName=GIA_DB_PoC;encrypt=true;trustServerCertificate=true;packetSize=4096
DATABASE_USER=jppirra_SQLLogin_1
DATABASE_PASSWORD=

# --------------------------------------------------------------------
# Backend Spring Boot.
# Puerto local. En despliegue, el host (Render/etc.) suele inyectar PORT.
# --------------------------------------------------------------------
PORT=8080

# URL pública del frontend (para CORS). Producción: https://tu-app.vercel.app
FRONTEND_URL=http://localhost:5173
