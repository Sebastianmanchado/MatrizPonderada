# =====================================================================
# Variables de entorno locales.
# Copiar a .env (mismo directorio que docker-compose.yml) y completar.
# El .env está gitignoreado: nunca commitear credenciales reales.
# =====================================================================

# --------------------------------------------------------------------
# PostgreSQL local (los lee docker-compose.yml para levantar la DB).
# --------------------------------------------------------------------
POSTGRES_USER=matriz
POSTGRES_PASSWORD=matriz_dev_password
POSTGRES_DB=matriz_ponderada

# --------------------------------------------------------------------
# Backend Spring Boot.
# En local apunta al Postgres de Docker (localhost:5432) con las
# mismas credenciales que arriba.
# En Render se sobrescriben con el connection string de Neon.
# --------------------------------------------------------------------
DATABASE_URL=jdbc:postgresql://localhost:5432/matriz_ponderada
DATABASE_USER=matriz
DATABASE_PASSWORD=matriz_dev_password

# Puerto del backend. Render inyecta PORT automáticamente; en local cae al default 8080.
PORT=8080

# URL pública del frontend (para CORS). Producción: https://tu-app.vercel.app
FRONTEND_URL=http://localhost:5173
