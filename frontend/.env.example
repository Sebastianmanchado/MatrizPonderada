# Local: backend en localhost:8080
VITE_API_BASE_URL=http://localhost:8080

# Vercel (producción) — elegí UNA opción:
#
# A) Proxy via vercel.json (recomendado si onrender.com está bloqueado en la red):
#    - NO definir VITE_API_BASE_URL en el panel de Vercel
#    - Root Directory del proyecto = frontend
#    - vercel.json debe apuntar al backend correcto en Render
#
# B) Llamada directa al backend:
#    VITE_API_BASE_URL=https://matriz-ponderada-backend.onrender.com
#    En Render: FRONTEND_URL=https://tu-app.vercel.app  (sin / final)
